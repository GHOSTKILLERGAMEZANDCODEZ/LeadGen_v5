# LeadGen v5 — Переменные окружения
# Скопируйте этот файл в .env и заполните значениями

# ===== Битрикс24 Вебхук =====
# URL вебхука для интеграции с Битрикс24
# Формат: https://<your-company>.bitrix24.ru/rest/<user_id>/<webhook_code>
BITRIX_WEBHOOK_URL=https://your-company.bitrix24.ru/rest/1/your_webhook_code/

# Лимит запросов к API Битрикс24 (запросов в секунду)
# Битрикс24 ограничивает количество запросов, рекомендуется 2-5 запросов/сек
BITRIX_API_CALLS_PER_SECOND=2

# ===== Настройки обработки =====
# Формат телефона: 7, 8, или +7
PHONE_FORMAT=7

# Минимальная длина номера
MIN_PHONE_LENGTH=10

# Удалять дубликаты (true/false)
REMOVE_DUPLICATES=true

# Игнорировать phone_2 (true/false)
IGNORE_PHONE_2=false

# ===== Настройки UI =====
# Тема: light или dark
UI_THEME=dark

# Размер шрифта
UI_FONT_SIZE=10

# ===== Пути =====
# Директория для входных файлов
INPUT_DIR=data/input

# Директория для выходных файлов
OUTPUT_DIR=data/output

# Файл базы данных
DATABASE_PATH=data/database.db

# ===== Логирование =====
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
